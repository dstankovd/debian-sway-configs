{
    "layer": "top",
    "position": "top",
    "height": 24,
    "spacing": 0,
    "exclusive": true,

    "modules-left": ["sway/workspaces", "custom/sep", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "network", "pulseaudio", "backlight", "sway/language", "battery"],

    "custom/sep": {
        "format": "|",
        "tooltip": false
    },

    "sway/window": {
        "max-length": 60,
        "tooltip": false
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        }
    },

    "clock": {
        "format": "{:%A %H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}"
    },

    "cpu": {
        "format": "<span size='small' color='#4a4a4a'>cpu </span>{usage}%",
        "interval": 2,
        "tooltip": true,
        "tooltip-format": "Load: {load}\n{avg_frequency}GHz avg"
    },

    "memory": {
        "format": "<span size='small' color='#4a4a4a'>mem </span>{percentage}%",
        "interval": 2,
        "tooltip": true,
        "tooltip-format": "RAM: {used}GiB / {total}GiB\nSwap: {swapUsed}GiB / {swapTotal}GiB"
    },

    "network": {
        "format-wifi": "<span size='small' color='#4a4a4a'>wifi </span>{signalStrength}%",
        "format-ethernet": "<span size='small' color='#4a4a4a'>eth</span>",
        "format-disconnected": "<span size='small' color='#4a4a4a'>net off</span>",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}"
    },

    "pulseaudio": {
        "format": "<span size='small' color='#4a4a4a'>vol </span>{volume}%",
        "format-muted": "<span size='small' color='#4a4a4a'>vol </span>muted",
        "tooltip": false,
        "on-click": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
    },

    "backlight": {
        "format": "<span size='small' color='#4a4a4a'>bri </span>{percent}%",
        "tooltip": false,
        "on-scroll-up": "brightnessctl set 2%+",
        "on-scroll-down": "brightnessctl set 2%-"
    },

    "sway/language": {
        "format": "{}",
        "tooltip": false
    },

    "battery": {
        "format": "<span size='small' color='#4a4a4a'>bat </span>{capacity}%",
        "format-charging": "<span size='small' color='#4a4a4a'>bat </span>{capacity}% <span size='small' color='#4a4a4a'>chr</span>",
        "format-plugged": "<span size='small' color='#4a4a4a'>bat </span>{capacity}%",
        "tooltip": true,
        "tooltip-format": "{time} remaining • {power}W"
    }
}
