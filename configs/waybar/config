{
    "layer": "top",
    "position": "top",
    "height": 24,
    "spacing": 0,
    "exclusive": true,

    "modules-left": ["sway/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "network", "sway/language", "battery"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        }
    },

    "clock": {
        "format": "{:%A %H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}"
    },

    "cpu": {
        "format": "cpu {usage}%",
        "interval": 2,
        "tooltip": false
    },

    "memory": {
        "format": "mem {percentage}%",
        "interval": 2,
        "tooltip": false
    },

    "network": {
        "format-wifi": "wifi {signalStrength}%",
        "format-ethernet": "eth",
        "format-disconnected": "no net",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}"
    },

    "sway/language": {
        "format": "{}",
        "tooltip": false
    },

    "battery": {
        "format": "{capacity}%",
        "format-charging": "{capacity}% +",
        "format-plugged": "{capacity}%",
        "format-icons": ["", "", "", "", ""],
        "tooltip": false
    }
}
