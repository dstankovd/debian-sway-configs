### Idle configuration
# Read `man swayidle` for options

exec_always pkill swayidle; swayidle -w \
    timeout 120 'brightnessctl -s set 20%' \
    resume 'brightnessctl -r' \
    timeout 300 'playerctl status 2>/dev/null | grep -q "^Playing$" || ~/.config/scripts/lock.sh' \
    timeout 600 'swaymsg "output * power off"' \
    resume 'swaymsg "output * power on"' \
    before-sleep '~/.config/scripts/lock.sh'
